{
	"name": "mercado-play",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"astro": "astro",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"dev": "astro dev",
		"dev:host": "astro dev --host",
		"format": "prettier --write .",
		"prepare": "husky",
		"compress:statics": "node ./scripts/compress/statics.js",
		"compress:statics-force": "node ./scripts/compress/statics.js --force",
		"generate:pwa-assets": "sh ./scripts/generate/pwa-assets.sh"
	},
	"lint-staged": {
		"**/*": "prettier --write --ignore-unknown"
	},
	"dependencies": {
		"@astrojs/react": "4.1.6",
		"@astrojs/tailwind": "5.1.5",
		"@inertiajs/react": "2.0.3",
		"astro": "5.1.8",
		"clsx": "2.1.1",
		"embla-carousel-react": "8.5.2",
		"justd-icons": "1.10.21",
		"motion": "12.0.6",
		"react": "19.0.0",
		"react-aria": "3.37.0",
		"react-aria-components": "1.6.0",
		"react-dom": "19.0.0",
		"sonner": "1.7.4",
		"tailwindcss": "3.4.17"
	},
	"devDependencies": {
		"@types/glob": "8.1.0",
		"@types/imagemin": "9.0.1",
		"@types/imagemin-webp": "7.0.3",
		"@types/react": "19.0.7",
		"@types/react-dom": "19.0.3",
		"glob": "11.0.1",
		"husky": "9.1.7",
		"image-size": "2.0.0",
		"imagemin": "9.0.0",
		"imagemin-webp": "8.0.0",
		"lint-staged": "15.4.1",
		"pngquant-bin": "9.0.0",
		"prettier": "3.4.2",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-jsxattribute-sort": "1.0.1",
		"prettier-plugin-merge": "0.7.2",
		"prettier-plugin-organize-imports": "4.1.0",
		"prettier-plugin-sort-json": "4.1.1",
		"prettier-plugin-tailwindcss": "0.6.10",
		"pwa-asset-generator": "6.4.0",
		"tailwind-merge": "2.6.0",
		"tailwind-variants": "0.3.1",
		"tailwindcss-animate": "1.0.7",
		"tailwindcss-react-aria-components": "1.2.0",
		"typescript": "5.7.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"cwebp-bin",
			"esbuild",
			"handbrake-js",
			"pngquant-bin",
			"sharp"
		]
	}
}
