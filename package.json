{
	"name": "mercado-play",
	"type": "module",
	"version": "0.0.1",
	"packageManager": "pnpm@10.6.5",
	"scripts": {
		"astro": "astro",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"dev": "astro dev",
		"dev:host": "astro dev --host",
		"format": "prettier --write .",
		"prepare": "husky",
		"resize": "tsx ./scripts/resize.ts",
		"compress:public": "tsx ./scripts/compress/public.ts",
		"download:youtube-video": "sh ./scripts/download/youtube-video.sh"
	},
	"lint-staged": {
		"**/*": "prettier --write --ignore-unknown"
	},
	"dependencies": {
		"@astrojs/react": "4.2.4",
		"@astrojs/sitemap": "3.3.0",
		"@fontsource-variable/geist": "5.2.5",
		"@fontsource-variable/geist-mono": "5.2.5",
		"@intentui/icons": "1.10.29",
		"@nanostores/react": "0.8.4",
		"@tailwindcss/vite": "4.0.14",
		"astro": "5.7.2",
		"clsx": "2.1.1",
		"embla-carousel-react": "8.5.2",
		"motion": "12.5.0",
		"nanostores": "0.11.4",
		"react": "19.0.0",
		"react-aria": "3.38.1",
		"react-aria-components": "1.7.1",
		"react-dom": "19.0.0",
		"sonner": "2.0.1",
		"tailwind-merge": "3.0.2",
		"tailwind-variants": "1.0.0",
		"tailwindcss": "4.1.3",
		"tailwindcss-react-aria-components": "2.0.0",
		"workbox-window": "7.3.0"
	},
	"devDependencies": {
		"@astrojs/check": "0.9.4",
		"@types/glob": "8.1.0",
		"@types/react": "19.0.12",
		"@types/react-dom": "19.0.4",
		"@vite-pwa/assets-generator": "0.2.6",
		"@vite-pwa/astro": "0.5.0",
		"embla-carousel-autoplay": "8.5.2",
		"husky": "9.1.7",
		"lint-staged": "15.5.0",
		"prettier": "3.5.3",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-organize-imports": "4.1.0",
		"prettier-plugin-sh": "0.15.0",
		"prettier-plugin-sort-json": "4.1.1",
		"prettier-plugin-tailwindcss": "0.6.11",
		"sharp": "0.33.5",
		"sharp-ico": "0.1.5",
		"tsx": "4.19.3",
		"tw-animate-css": "1.2.4",
		"typescript": "5.8.2",
		"vite-plugin-pwa": "0.21.1"
	},
	"pnpm": {
		"overrides": {
			"sharp": "0.33.5"
		},
		"onlyBuiltDependencies": [
			"esbuild",
			"handbrake-js",
			"sharp"
		]
	}
}
