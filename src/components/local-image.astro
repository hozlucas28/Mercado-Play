---
import { BREAKPOINTS, COMPRESS_CONFIGURATION } from '@/constants'
import type { Breakpoint, BreakpointWidth } from '@/types'
import type { HTMLAttributes } from 'astro/types'
import { Picture } from 'astro:assets'

/* ---------------------------------- Types --------------------------------- */

interface Props extends Omit<HTMLAttributes<'img'>, 'alt' | 'src' | 'srcset' | 'width' | 'height' | 'sizes'> {
	alt: string
	src: ImageMetadata
	quality?: Parameters<typeof Picture>[0]['quality']
	pictureAttributes?: HTMLAttributes<'picture'>
}

type Size = `(min-width: ${number}px) ${number}px`

/* ---------------------------------- Logic --------------------------------- */

const props: Props = Astro.props

const sizes: Size[] = []
const widths: BreakpointWidth[] = []

for (const breakpoint in BREAKPOINTS) {
	const _breakpoint = breakpoint as Breakpoint
	const width: BreakpointWidth = BREAKPOINTS[_breakpoint]

	widths.push(width)
	sizes.push(`(min-width: ${width}px) ${width}px`)
}

export type { Props as LocalImageProps, Size }
---

<Picture
	sizes={sizes.join(', ')}
	formats={Object.keys(COMPRESS_CONFIGURATION.images.outputFormats)}
	quality={'high'}
	{widths}
	{...props}
/>
