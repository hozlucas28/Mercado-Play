---
import { BREAKPOINTS } from '@/constants'
import { Picture } from 'astro:assets'

interface Props {
	alt: string
	src: ImageMetadata
}

const { alt, src }: Props = Astro.props

const widths: number[] = []
for (const breakpoint in BREAKPOINTS) {
	widths.push(BREAKPOINTS[breakpoint as keyof typeof BREAKPOINTS])
}

const sizes: `(max-width: ${number}px) ${number}px`[] = []
for (const width of widths) sizes.push(`(max-width: ${width}px) ${width}px`)
---

<Picture
	{alt}
	{src}
	{widths}
	sizes={sizes.join(', ')}
	fallbackFormat='png'
	formats={['avif', 'webp']}
	quality='high'
/>
