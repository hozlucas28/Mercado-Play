---
import HeroSkeleton from '@/components/hero-skeleton.astro'
import type { Slide } from '@/components/hero.tsx'
import Hero from '@/components/hero.tsx'
import MediaCarouselSkeleton from '@/components/media-carousel-skeleton.astro'
import type { Media } from '@/components/media-carousel.tsx'
import MediaCarousel from '@/components/media-carousel.tsx'
import { heroSlide } from '@/components/utils/hero-slide.ts'
import type { MediaData } from '@/components/utils/media-slide.ts'
import { mediaSlide } from '@/components/utils/media-slide.ts'
import { COMPRESS_CONFIGURATION } from '@/constants.ts'
import Layout from '@/layouts/index.astro'

import animationData from './assets/animation/_data.json'
import bingeWatchSeriesData from './assets/binge-watch-series/_data.json'
import blockbusterMoviesData from './assets/blockbuster-movies/_data.json'
import comedyData from './assets/comedy/_data.json'
import continueWatchingData from './assets/continue-watching/_data.json'
import heroData from './assets/hero/_data.json'
import myListData from './assets/my-list/_data.json'
import recentlyAddedData from './assets/recently-added/_data.json'

import nodePath from 'node:path'

/* ---------------------------------- Types --------------------------------- */

type MediaCollection = {
	$schema: string
} & Record<string, Omit<MediaData, 'id' | 'anchor' | 'date'> & { date: string }>

/* ------------------------------ Configuration ----------------------------- */

const {
	outputDevices: _outputDevices,
	outputFormats: _outputFormats,
	captions: _captions,
} = COMPRESS_CONFIGURATION.videos

/* --------------------------------- Helpers -------------------------------- */

async function mediaSlides(
	data: MediaCollection,
	images: Record<string, { default: ImageMetadata }>,
	dataConstructor: (data: { id: string } & MediaCollection['']) => Parameters<typeof mediaSlide>['0']
): Promise<Media[]> {
	const slides: Media[] = []

	for (const id in data) {
		if (id === '$schema') continue

		const _data = data[id]
		const _images: ImageMetadata[] = []

		for (const src in images) {
			if (src.search(id) === -1) continue
			const image: ImageMetadata = images[src].default
			_images.push(image)
		}

		const slide = mediaSlide(dataConstructor({ id, ..._data }), _images)

		slides.push(slide)
	}

	return slides
}

/* ---------------------------------- Logic --------------------------------- */

const hero: Slide[] = []
const heroMedia = import.meta.glob<{ default: string | ImageMetadata }>('./assets/hero/**/_*.(webp|webm|mp4|vtt)', {
	eager: true,
})

for (const id in heroData) {
	const _id = id as keyof typeof heroData
	if (_id === '$schema') continue

	const data = heroData[_id]
	let poster: string = ''
	const videos: string[] = []
	const captions: string[] = []

	for (const src in heroMedia) {
		if (src.search(id) === -1) continue

		const type: string = nodePath.extname(src)
		const media = heroMedia[src].default

		if (type === '.webp') {
			poster = (media as ImageMetadata).src
		} else if (_outputFormats.includes(type.slice(1) as (typeof _outputFormats)[number])) {
			videos.push(media as string)
		} else if (type === '.vtt') {
			captions.push(media as string)
		}
	}

	const slide = heroSlide({
		data: {
			id,
			...data,
			poster: {
				...data.poster,
				src: poster,
			},
		},
		videos,
		captions,
	})

	hero.push(slide)
}

// TODO: use IMDB API to fetch "My list" data from local storage.
const myList: Media[] = await mediaSlides(
	myListData as unknown as MediaCollection,
	import.meta.glob<{ default: ImageMetadata }>('./assets/my-list/**/_*.(avif|webp|jpg)', { eager: true }),
	(data) => ({
		...data,
		anchor: { href: `/${data.id}` },
		date: new Date(data.date),
	})
)

const continueWatching: Media[] = await mediaSlides(
	continueWatchingData as unknown as MediaCollection,
	import.meta.glob<{ default: ImageMetadata }>('./assets/continue-watching/**/_*.(avif|webp|jpg)', { eager: true }),
	(data) => ({
		...data,
		anchor: { href: `/${data.id}` },
		date: undefined,
		progress: {
			value: Math.floor(Math.random() * 76) + 15,
			position: 'out',
		},
	})
)

const recentlyAdded: Media[] = await mediaSlides(
	recentlyAddedData as unknown as MediaCollection,
	import.meta.glob<{ default: ImageMetadata }>('./assets/recently-added/**/_*.(avif|webp|jpg)', { eager: true }),
	(data) => ({
		...data,
		anchor: { href: `/${data.id}` },
		date: new Date(data.date),
	})
)

const blockbusterMovies: Media[] = await mediaSlides(
	blockbusterMoviesData as unknown as MediaCollection,
	import.meta.glob<{ default: ImageMetadata }>('./assets/blockbuster-movies/**/_*.(avif|webp|jpg)', { eager: true }),
	(data) => ({
		...data,
		anchor: { href: `/${data.id}` },
		date: new Date(data.date),
	})
)

const bingeWatchSeries: Media[] = await mediaSlides(
	bingeWatchSeriesData as unknown as MediaCollection,
	import.meta.glob<{ default: ImageMetadata }>('./assets/binge-watch-series/**/_*.(avif|webp|jpg)', { eager: true }),
	(data) => ({
		...data,
		anchor: { href: `/${data.id}` },
		date: new Date(data.date),
	})
)

const comedy: Media[] = await mediaSlides(
	comedyData as unknown as MediaCollection,
	import.meta.glob<{ default: ImageMetadata }>('./assets/comedy/**/_*.(avif|webp|jpg)', { eager: true }),
	(data) => ({
		...data,
		anchor: { href: `/${data.id}` },
		date: new Date(data.date),
	})
)

const animation: Media[] = await mediaSlides(
	animationData as unknown as MediaCollection,
	import.meta.glob<{ default: ImageMetadata }>('./assets/animation/**/_*.(avif|webp|jpg)', { eager: true }),
	(data) => ({
		...data,
		anchor: { href: `/${data.id}` },
		date: new Date(data.date),
	})
)
---

{
	hero.map((item) => (
		<link
			as='image'
			rel='preload'
			fetchpriority='high'
			href={item.poster.src}
		/>
	))
}

<Layout>
	<!-- Hero -->
	<Hero
		slides={hero}
		client:only='react'
	>
		<HeroSkeleton
			slides={hero.length}
			slot='fallback'
		/>
	</Hero>

	<!-- My list -->
	<MediaCarousel
		title='Mi lista'
		slides={myList}
		options={{
			prioritizeRender: true,
			prioritizeImgLoad: true,
		}}
		client:only='react'
	>
		<MediaCarouselSkeleton
			title='Mi lista'
			slides={myList.length}
			options={{
				title: !!myList.at(0)?.title,
				date: !!myList.at(0)?.date,
				progress: myList.at(0)?.progress?.position,
			}}
			slot='fallback'
		/>
	</MediaCarousel>

	<!-- Continue watching -->
	<MediaCarousel
		title='Continuar viendo'
		slides={continueWatching}
		options={{
			prioritizeRender: true,
			prioritizeImgLoad: true,
		}}
		client:only='react'
	>
		<MediaCarouselSkeleton
			title='Continuar viendo'
			slides={continueWatching.length}
			options={{
				title: !!continueWatching.at(0)?.title,
				date: !!continueWatching.at(0)?.date,
				progress: continueWatching.at(0)?.progress?.position,
			}}
			slot='fallback'
		/>
	</MediaCarousel>

	<!-- Recently added -->
	<MediaCarousel
		title='Agregadas recientemente'
		slides={recentlyAdded}
		client:only='react'
	>
		<MediaCarouselSkeleton
			title='Agregadas recientemente'
			slides={recentlyAdded.length}
			options={{
				title: !!recentlyAdded.at(0)?.title,
				date: !!recentlyAdded.at(0)?.date,
				progress: recentlyAdded.at(0)?.progress?.position,
			}}
			slot='fallback'
		/>
	</MediaCarousel>

	<!-- Blockbuster movies -->
	<MediaCarousel
		title='Películas taquilleras'
		slides={blockbusterMovies}
		client:only='react'
	>
		<MediaCarouselSkeleton
			title='Películas taquilleras'
			slides={blockbusterMovies.length}
			options={{
				title: !!blockbusterMovies.at(0)?.title,
				date: !!blockbusterMovies.at(0)?.date,
				progress: blockbusterMovies.at(0)?.progress?.position,
			}}
			slot='fallback'
		/>
	</MediaCarousel>

	<!-- Series to binge-watch -->
	<MediaCarousel
		title='Series para maratonear'
		slides={bingeWatchSeries}
		client:only='react'
	>
		<MediaCarouselSkeleton
			title='Series para maratonear'
			slides={bingeWatchSeries.length}
			options={{
				title: !!bingeWatchSeries.at(0)?.title,
				date: !!bingeWatchSeries.at(0)?.date,
				progress: bingeWatchSeries.at(0)?.progress?.position,
			}}
			slot='fallback'
		/>
	</MediaCarousel>

	<!-- Comedy -->
	<MediaCarousel
		title='Comedia'
		slides={comedy}
		client:only='react'
	>
		<MediaCarouselSkeleton
			title='Comedia'
			slides={comedy.length}
			options={{
				title: !!comedy.at(0)?.title,
				date: !!comedy.at(0)?.date,
				progress: comedy.at(0)?.progress?.position,
			}}
			slot='fallback'
		/>
	</MediaCarousel>

	<!-- Animation -->
	<MediaCarousel
		title='Animación'
		slides={animation}
		client:only='react'
	>
		<MediaCarouselSkeleton
			title='Animación'
			slides={animation.length}
			options={{
				title: !!animation.at(0)?.title,
				date: !!animation.at(0)?.date,
				progress: animation.at(0)?.progress?.position,
			}}
			slot='fallback'
		/>
	</MediaCarousel>
</Layout>
