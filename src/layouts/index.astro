---
import Brand from '@/components/brand.astro'
import type { AvatarProps } from '@/components/header'

import Header from '@/components/header'

import { BRAND } from '@/constants'
import type { Page } from '@/types'

import Avatar from './assets/user-avatar.jpg'

import Template from './template.astro'

const pageURL: Page = '/'

const avatar: AvatarProps = {
	src: Avatar.src,
	alt: 'Esteban Gutierrez',
	initials: 'EG',
}
---

<Template
	locale='es'
	title=`${BRAND.name} - Ver Películas y Series Gratis`
	description={BRAND.description}
	keywords='ver online, ver en línea, películas, ver películas, películas online, películas en línea, películas completas, películas en streaming, series, ver series, series online, series en línea, series completas, series en streaming, ver programas, programas online, programas en línea'
	pageURL={pageURL}
>
	<Header
		{avatar}
		currentPage={pageURL}
		slot='header'
		client:only='react'
		DesktopBrand
		MobileBrand
	>
		<Brand
			class='h-12 w-auto md:h-9'
			loading='eager'
			pictureAttributes={{ class: 'h-12 md:h-9 w-auto' }}
			slot='DesktopBrand'
		/>
		<Brand
			class='h-8 w-auto'
			loading='eager'
			pictureAttributes={{ class: 'h-8 w-auto' }}
			slot='MobileBrand'
		/>
	</Header>

	<slot />
</Template>
