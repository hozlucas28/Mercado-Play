---
import Brand from '@/components/brand.astro'
import Footer from '@/components/footer.astro'
import type { AvatarProps } from '@/components/header'
import Header from '@/components/header'
import HeaderSkeleton from '@/components/header-skeleton.astro'

import { BRAND } from '@/constants'
import type { Page } from '@/types'

import Avatar from './assets/user-avatar.jpg'

import Template from './template.astro'

const pageURL: Page = '/'

const avatar: AvatarProps = {
	src: Avatar.src,
	alt: 'Avatar de Esteban Gutierrez.',
	initials: 'EG',
}
---

<Template
	locale='es'
	title=`${BRAND.name} | Películas y Series Gratis`
	description={BRAND.description}
	keywords='películas, ver películas, películas online, películas en línea, películas completas, películas en streaming, series, ver series, series online, series en línea, series completas, series en streaming, lucas hoz, hoz lucas, lucashoz, hozlucas, hozlucas28'
	pageURL={pageURL}
	classes={{
		body: {
			main: {
				wrapper:
					'*:mb-5 [:is(&>astro-island)]:*:mb-4 sm:*:mb-6 sm:[:is(&>astro-island)]:*:mb-6 lg:*:mb-12 lg:[:is(&>astro-island)]:*:mb-12',
			},
			footer: 'px-2.5 pb-2.5 mt-4 sm:mt-6 lg:mt-12',
		},
	}}
>
	<Header
		{avatar}
		currentPage={pageURL}
		slot='header'
		client:only='react'
		DesktopBrand
		MobileBrand
	>
		<HeaderSkeleton slot='fallback' />
		<Brand
			class='h-12 w-auto md:h-9'
			loading='eager'
			pictureAttributes={{ class: 'h-12 md:h-9 w-auto' }}
			slot='DesktopBrand'
		/>
		<Brand
			class='h-8 w-auto'
			loading='eager'
			pictureAttributes={{ class: 'h-8 w-auto' }}
			slot='MobileBrand'
		/>
	</Header>

	<slot />

	<Footer slot='footer' />
</Template>
