---
import type { AvatarProps } from '@/components/header'
import Header from '@/components/header'
import { BRAND_NAME } from '@/constants'
import type { Page } from '@/types'
import Template from './template.astro'

const pageURL: Page = '/'

const avatar: AvatarProps = {
	src: 'https://avatars.githubusercontent.com/u/88015479',
	alt: 'hozlucas28',
	initials: 'HZ',
}
---

<Template
	title=`${BRAND_NAME} - Ver Películas y Series Gratis`
	description=`Encontrá series y películas gratis en ${BRAND_NAME}. Explorá cientos de películas y series sin costo alguno.`
	keywords='ver online, ver en línea, películas, ver películas, películas online, películas en línea, películas completas, películas en streaming, series, ver series, series online, series en línea, series completas, series en streaming, ver programas, programas online, programas en línea'
	locale='es'
	pageURL={pageURL}
>
	<Header {avatar} currentPage={pageURL} slot='header' client:only='react' />
	<slot />
</Template>
