	<body class='font-sans antialiased'>
		<slot name='header' />
		<main>
			<slot />
		</main>
		<slot name='footer' />
	</body>
	<script>
		import { DEFAULT_THEME, DEFAULT_THEME_STORAGE_KEY } from '@/constants'
		import type { Theme } from '@/types'

		const darkTheme: Theme = 'dark'
		const lightTheme: Theme = 'light'

		const themePreference: Theme =
			(localStorage.getItem(DEFAULT_THEME_STORAGE_KEY) as Theme) ??
			DEFAULT_THEME
		document.documentElement.classList[
			themePreference === darkTheme ? 'add' : 'remove'
		](darkTheme)

		const observer = new MutationObserver(() => {
			const isDark: boolean =
				document.documentElement.classList.contains(darkTheme)
			localStorage.setItem(
				DEFAULT_THEME_STORAGE_KEY,
				isDark ? darkTheme : lightTheme
			)
		})

		observer.observe(document.documentElement, {
			attributes: true,
			attributeFilter: ['class'],
		})
	</script>
