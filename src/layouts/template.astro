---
import { BRAND_NAME } from '@/constants'
import '../styles/app.css'
import type { Page, Locale } from '@/types'

type Props = {
	title: string
	description: string
	keywords: string
	locale: Locale
	pageURL: Page
}

const { title, description, keywords, locale, pageURL } = Astro.props
