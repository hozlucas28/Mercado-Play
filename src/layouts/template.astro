---
import { BRAND } from '@/constants'
import '@/styles/globals.css'
import type { Page, Locale } from '@/types'
import { pwaInfo } from 'virtual:pwa-info'
import { pwaAssetsHead } from 'virtual:pwa-assets/head'

type Props = {
	locale: Locale
	title: string
	description: string
	keywords: string
	pageURL: Page
}

const { locale, title, description, keywords, pageURL } = Astro.props
---

<html
	dir='ltr'
	lang={locale}
>
	<head>
		<meta charset='UTF-8' />
		<meta
			name='robots'
			content='index, follow'
		/>
		<meta
			name='mobile-web-app-capable'
			content='yes'
		/>
		<meta
			name='viewport'
			content='width=device-width, initial-scale=1.0'
		/>
		<meta
			http-equiv='X-UA-Compatible'
			content='IE=edge'
		/>

		<title>{title}</title>
		<meta
			name='description'
			content={description}
		/>
		<meta
			name='keywords'
			content={keywords}
		/>
		<meta
			name='Author'
			content='Lucas Hoz'
			lang={locale}
		/>
		<meta
			name='copyright'
			content='Lucas Hoz'
		/>
		<meta
			name='generator'
			content={Astro.generator}
		/>

		<link
			rel='alternate'
			href={pageURL}
			hreflang='x-default'
		/>

		{pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}

		{
			pwaAssetsHead.themeColor && (
				<meta
					name={pwaAssetsHead.themeColor.name}
					content={pwaAssetsHead.themeColor.content}
				/>
			)
		}

		<meta
			name='apple-mobile-web-app-title'
			content={BRAND.name}
		/>
		<meta
			name='apple-mobile-web-app-status-bar-style'
			content='default'
		/>

		{pwaAssetsHead.links.map((link) => <link {...link} />)}

		<meta
			property='og:type'
			content='website'
		/>
		<meta
			property='og:url'
			content={pageURL}
		/>
		<meta
			property='og:locale'
			content={locale}
		/>
		<meta
			property='og:title'
			content={title}
		/>
		<meta
			property='og:site_name'
			content={BRAND.name}
		/>
		<meta
			property='og:description'
			content={description}
		/>

		<meta
			property='og:image'
			content='/open-graphs/app.avif'
		/>
		<meta
			property='og:image:type'
			content='image/avif'
		/>
		<meta
			property='og:image:width'
			content='1200'
		/>
		<meta
			property='og:image:height'
			content='630'
		/>

		<meta
			property='og:image'
			content='/open-graphs/app.webp'
		/>
		<meta
			property='og:image:type'
			content='image/webp'
		/>
		<meta
			property='og:image:width'
			content='1200'
		/>
		<meta
			property='og:image:height'
			content='630'
		/>

		<meta
			property='og:image'
			content='/open-graphs/app.png'
		/>
		<meta
			property='og:image:type'
			content='image/png'
		/>
		<meta
			property='og:image:width'
			content='1200'
		/>
		<meta
			property='og:image:height'
			content='630'
		/>

		<meta
			name='twitter:card'
			content='summary_large_image'
		/>
		<meta
			name='twitter:url'
			content={pageURL}
		/>
		<meta
			name='twitter:title'
			content={title}
		/>
		<meta
			name='twitter:description'
			content={description}
		/>
		<meta
			name='twitter:creator'
			content='@hozlucas28'
		/>
		<meta
			name='twitter:image'
			content='/open-graphs/app__twitter.webp'
		/>
		<meta
			name='twitter:image:alt'
			content='Rediseño de Mercado Play, desarrollado por @hozlucas28.'
		/>
	</head>

	<body class='h-screen bg-red-500 font-sans antialiased'>
		<slot name='header' />
		<main>
			<slot />
		</main>
		<slot name='footer' />
	</body>

	<script>
		import { DEFAULT_THEME, DEFAULT_THEME_STORAGE_KEY } from '@/constants'
		import type { Theme } from '@/types'

		const darkTheme: Theme = 'dark'
		const lightTheme: Theme = 'light'

		const themePreference: Theme = (localStorage.getItem(DEFAULT_THEME_STORAGE_KEY) as Theme) ?? DEFAULT_THEME
		document.documentElement.classList[themePreference === darkTheme ? 'add' : 'remove'](darkTheme)

		const observer = new MutationObserver(() => {
			const isDark: boolean = document.documentElement.classList.contains(darkTheme)
			localStorage.setItem(DEFAULT_THEME_STORAGE_KEY, isDark ? darkTheme : lightTheme)
		})

		observer.observe(document.documentElement, {
			attributes: true,
			attributeFilter: ['class'],
		})
	</script>
</html>
