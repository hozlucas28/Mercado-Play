{
	"compilerOptions": {
		"baseUrl": ".",
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"paths": {
			"@/*": ["src/*"],
			"ui": ["src/components/ui/index.ts"]
		},
		"sourceMap": true,
		"strictNullChecks": true
	},
	"exclude": ["dist"],
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"]
}
